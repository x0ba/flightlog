# Local Docker Postgres (see compose.yaml): postgresql://postgres:postgres@localhost:5432/flightlog
# Production (Neon): postgresql://user:pass@ep-....neon.tech/neondb?sslmode=require
DATABASE_URL=
FLIGHTLOG_KEYS_SECRET=
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:5173/callback
WORKOS_COOKIE_PASSWORD=
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
OPENAI_API_KEY=
OPENAI_OAUTH_CLIENT_ID=
# Optional: registered redirect URI for browser OAuth (otherwise device-code flow)
OPENAI_OAUTH_REDIRECT_URI=
OPENAI_OAUTH_DEVICE_AUTH=auto
OPENAI_AGENT_MODEL=computer-use-preview
OPENAI_EVAL_MODEL=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
FLIGHTLOG_AGENT_MAX_STEPS=20
FLIGHTLOG_AGENT_APPROVAL_TIMEOUT_SECONDS=300
